&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span style="white-space:pre;-webkit-user-select:none;user-select:none;margin-right:0.4em;padding:0 0.4em 0 0.4em;color:#6e7681"&gt; 5&lt;/span&gt;&lt;span&gt; &lt;span style="color:#79c0ff"&gt;$user&lt;/span&gt; &lt;span style="color:#ff7b72;font-weight:bold"&gt;=&lt;/span&gt; &lt;span style="color:#79c0ff"&gt;$_GET&lt;/span&gt;[ &lt;span style="color:#a5d6ff"&gt;&amp;#39;username&amp;#39;&lt;/span&gt; ];
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span style="white-space:pre;-webkit-user-select:none;user-select:none;margin-right:0.4em;padding:0 0.4em 0 0.4em;color:#6e7681"&gt; 6&lt;/span&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span style="white-space:pre;-webkit-user-select:none;user-select:none;margin-right:0.4em;padding:0 0.4em 0 0.4em;color:#6e7681"&gt; 7&lt;/span&gt;&lt;span&gt; &lt;span style="color:#8b949e;font-style:italic"&gt;// Get password
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span style="white-space:pre;-webkit-user-select:none;user-select:none;margin-right:0.4em;padding:0 0.4em 0 0.4em;color:#6e7681"&gt; 8&lt;/span&gt;&lt;span&gt; &lt;span style="color:#79c0ff"&gt;$pass&lt;/span&gt; &lt;span style="color:#ff7b72;font-weight:bold"&gt;=&lt;/span&gt; &lt;span style="color:#79c0ff"&gt;$_GET&lt;/span&gt;[ &lt;span style="color:#a5d6ff"&gt;&amp;#39;password&amp;#39;&lt;/span&gt; ];
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span style="white-space:pre;-webkit-user-select:none;user-select:none;margin-right:0.4em;padding:0 0.4em 0 0.4em;color:#6e7681"&gt; 9&lt;/span&gt;&lt;span&gt; &lt;span style="color:#79c0ff"&gt;$pass&lt;/span&gt; &lt;span style="color:#ff7b72;font-weight:bold"&gt;=&lt;/span&gt; md5( &lt;span style="color:#79c0ff"&gt;$pass&lt;/span&gt; );
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span style="white-space:pre;-webkit-user-select:none;user-select:none;margin-right:0.4em;padding:0 0.4em 0 0.4em;color:#6e7681"&gt;10&lt;/span&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span style="white-space:pre;-webkit-user-select:none;user-select:none;margin-right:0.4em;padding:0 0.4em 0 0.4em;color:#6e7681"&gt;11&lt;/span&gt;&lt;span&gt; &lt;span style="color:#8b949e;font-style:italic"&gt;// Check the database
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span style="white-space:pre;-webkit-user-select:none;user-select:none;margin-right:0.4em;padding:0 0.4em 0 0.4em;color:#6e7681"&gt;12&lt;/span&gt;&lt;span&gt; &lt;span style="color:#79c0ff"&gt;$query&lt;/span&gt; &lt;span style="color:#ff7b72;font-weight:bold"&gt;=&lt;/span&gt; &lt;span style="color:#a5d6ff"&gt;&amp;#34;SELECT * FROM `users` WHERE user = &amp;#39;&lt;/span&gt;&lt;span style="color:#a5d6ff"&gt;$user&lt;/span&gt;&lt;span style="color:#a5d6ff"&gt;&amp;#39; AND password = &amp;#39;&lt;/span&gt;&lt;span style="color:#a5d6ff"&gt;$pass&lt;/span&gt;&lt;span style="color:#a5d6ff"&gt;&amp;#39;;&amp;#34;&lt;/span&gt;;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span style="white-space:pre;-webkit-user-select:none;user-select:none;margin-right:0.4em;padding:0 0.4em 0 0.4em;color:#6e7681"&gt;13&lt;/span&gt;&lt;span&gt; &lt;span style="color:#79c0ff"&gt;$result&lt;/span&gt; &lt;span style="color:#ff7b72;font-weight:bold"&gt;=&lt;/span&gt; mysqli_query(&lt;span style="color:#79c0ff"&gt;$GLOBALS&lt;/span&gt;[&lt;span style="color:#a5d6ff"&gt;&amp;#34;___mysqli_ston&amp;#34;&lt;/span&gt;], &lt;span style="color:#79c0ff"&gt;$query&lt;/span&gt; ) &lt;span style="color:#ff7b72"&gt;or&lt;/span&gt; &lt;span style="color:#ff7b72"&gt;die&lt;/span&gt;( &lt;span style="color:#a5d6ff"&gt;&amp;#39;&amp;lt;pre&amp;gt;&amp;#39;&lt;/span&gt; &lt;span style="color:#ff7b72;font-weight:bold"&gt;.&lt;/span&gt; ((is_object(&lt;span style="color:#79c0ff"&gt;$GLOBALS&lt;/span&gt;[&lt;span style="color:#a5d6ff"&gt;&amp;#34;___mysqli_ston&amp;#34;&lt;/span&gt;])) &lt;span style="color:#ff7b72;font-weight:bold"&gt;?&lt;/span&gt; mysqli_error(&lt;span style="color:#79c0ff"&gt;$GLOBALS&lt;/span&gt;[&lt;span style="color:#a5d6ff"&gt;&amp;#34;___mysqli_ston&amp;#34;&lt;/span&gt;]) &lt;span style="color:#ff7b72;font-weight:bold"&gt;:&lt;/span&gt; ((&lt;span style="color:#79c0ff"&gt;$___mysqli_res&lt;/span&gt; &lt;span style="color:#ff7b72;font-weight:bold"&gt;=&lt;/span&gt; mysqli_connect_error()) &lt;span style="color:#ff7b72;font-weight:bold"&gt;?&lt;/span&gt; &lt;span style="color:#79c0ff"&gt;$___mysqli_res&lt;/span&gt; &lt;span style="color:#ff7b72;font-weight:bold"&gt;:&lt;/span&gt; &lt;span style="color:#ff7b72"&gt;false&lt;/span&gt;)) &lt;span style="color:#ff7b72;font-weight:bold"&gt;.&lt;/span&gt; &lt;span style="color:#a5d6ff"&gt;&amp;#39;&amp;lt;/pre&amp;gt;&amp;#39;&lt;/span&gt; );
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span style="white-space:pre;-webkit-user-select:none;user-select:none;margin-right:0.4em;padding:0 0.4em 0 0.4em;color:#6e7681"&gt;14&lt;/span&gt;&lt;span&gt;
